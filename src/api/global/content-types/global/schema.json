{
  "kind": "singleType",
  "collectionName": "globals",
  "info": {
    "singularName": "global",
    "pluralName": "globals",
    "displayName": "Global",
    "description": "Site-wide settings: logo, contact info, social links"
  },
  "options": { "draftAndPublish": false },
  "pluginOptions": {},
  "attributes": {
    "siteName": { "type": "string", "required": true },
    "logoLight": { "type": "media", "multiple": false, "allowedTypes": ["images"] },
    "logoDark": { "type": "media", "multiple": false, "allowedTypes": ["images"] },
    "favicon": { "type": "media", "multiple": false, "allowedTypes": ["images", "files"] },
    "phoneNumber": { "type": "string" },
    "email": { "type": "email" },
    "officeAddress": { "type": "text" },
    "brochureFile": { "type": "media", "multiple": false, "allowedTypes": ["files"] },
    "socialLinks": { "type": "component", "repeatable": true, "component": "shared.social-link" },
    "headerCta": { "type": "component", "repeatable": false, "component": "shared.cta-button" },
    "defaultSeo": { "type": "component", "repeatable": false, "component": "shared.seo" }
  }
}
